<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/com_facebook_sso_noapp_background"
    android:orientation="vertical"
    android:paddingBottom="16dp">

    <!-- Header: close button + logo + title -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="0dp"
        android:paddingEnd="16dp"
        android:paddingTop="24dp"
        android:paddingBottom="2dp">

        <ImageButton
            android:id="@+id/com_facebook_sso_noapp_close"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/com_facebook_loginview_cancel_action"
            android:padding="6dp"
            android:scaleType="fitCenter"
            android:src="@drawable/com_facebook_sso_close" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@string/com_facebook_loginview_log_in_button_long"
                android:src="@drawable/com_facebook_sso_logo" />

            <TextView
                android:id="@+id/com_facebook_sso_noapp_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:fontFamily="@font/optimistic_vf"
                android:text="@string/com_facebook_sso_noapp_title"
                android:textColor="#0A1317"
                android:textSize="17sp"
                android:textFontWeight="600" />
        </LinearLayout>
    </RelativeLayout>

    <!-- Body -->
    <TextView
        android:id="@+id/com_facebook_sso_noapp_body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="-8dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp"
        android:fontFamily="@font/optimistic_vf"
        android:text="@string/com_facebook_sso_noapp_body"
        android:textColor="#0A1317"
        android:textSize="15sp" />

    <!-- Continue with Facebook button -->
    <Button
        android:id="@+id/com_facebook_sso_noapp_continue"
        android:stateListAnimator="@null"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/com_facebook_sso_noapp_continue_button_bg"
        android:gravity="center"
        android:fontFamily="@font/optimistic_vf"
        android:text="@string/com_facebook_loginview_log_in_button_continue"
        android:textAllCaps="false"
        android:textColor="#F1F4F7"
        android:textSize="15sp" />

    <!-- Not now button -->
    <Button
        android:id="@+id/com_facebook_sso_noapp_not_now"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/com_facebook_sso_noapp_not_now_button_bg"
        android:gravity="center"
        android:fontFamily="@font/optimistic_vf"
        android:text="@string/com_facebook_sso_noapp_not_now"
        android:textAllCaps="false"
        android:textColor="#0A1317"
        android:textSize="15sp" />
</LinearLayout>
