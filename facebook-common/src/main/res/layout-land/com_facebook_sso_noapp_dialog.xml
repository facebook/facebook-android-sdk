<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/com_facebook_sso_noapp_background"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingBottom="24dp">

    <!-- Header: logo + title + close button (close on right in landscape) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@string/com_facebook_loginview_log_in_button_long"
            android:src="@drawable/com_facebook_sso_logo" />

        <TextView
            android:id="@+id/com_facebook_sso_noapp_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:fontFamily="@font/optimistic_vf"
            android:text="@string/com_facebook_sso_noapp_title"
            android:textColor="#0A1317"
            android:textSize="17sp"
            android:textFontWeight="600" />

        <ImageButton
            android:id="@+id/com_facebook_sso_noapp_close"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/com_facebook_loginview_cancel_action"
            android:padding="4dp"
            android:scaleType="centerInside"
            android:src="@drawable/com_facebook_sso_close" />
    </LinearLayout>

    <!-- Body -->
    <TextView
        android:id="@+id/com_facebook_sso_noapp_body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="20dp"
        android:fontFamily="@font/optimistic_vf"
        android:text="@string/com_facebook_sso_noapp_body"
        android:textColor="#0A1317"
        android:textSize="15sp" />

    <!-- Buttons side by side -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Not now button -->
        <Button
            android:id="@+id/com_facebook_sso_noapp_not_now"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/com_facebook_sso_noapp_not_now_button_bg"
            android:gravity="center"
            android:fontFamily="@font/optimistic_vf"
            android:text="@string/com_facebook_sso_noapp_not_now"
            android:textAllCaps="false"
            android:textColor="#0A1317"
            android:textSize="15sp" />

        <!-- Continue with Facebook button -->
        <Button
            android:id="@+id/com_facebook_sso_noapp_continue"
            android:stateListAnimator="@null"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="2"
            android:layout_marginStart="8dp"
            android:background="@drawable/com_facebook_sso_noapp_continue_button_bg"
            android:gravity="center"
            android:fontFamily="@font/optimistic_vf"
            android:text="@string/com_facebook_loginview_log_in_button_continue"
            android:textAllCaps="false"
            android:textColor="#F1F4F7"
            android:textSize="15sp" />
    </LinearLayout>
</LinearLayout>
